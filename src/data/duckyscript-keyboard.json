  "syntax_reference": [
    {"command": "REM", "syntax": "REM <comment>", "example": "REM This is a comment", "desc": "Non-executed comment/documentation line"},
    {"command": "DELAY", "syntax": "DELAY <ms>", "example": "DELAY 1000", "desc": "Pause execution for specified milliseconds"},
    {"command": "STRING", "syntax": "STRING <text>", "example": "STRING Hello World", "desc": "Type text as rapid keystrokes"},
    {"command": "ENTER", "syntax": "ENTER", "example": "ENTER", "desc": "Press Enter/Return key"},
    {"command": "GUI", "syntax": "GUI [key]", "example": "GUI r", "desc": "Windows key (optionally with another key)"},
    {"command": "CTRL", "syntax": "CTRL [key]", "example": "CTRL ALT t", "desc": "Control key combo"},
    {"command": "ALT", "syntax": "ALT [key]", "example": "ALT F4", "desc": "Alt key combo"},
    {"command": "SHIFT", "syntax": "SHIFT [key]", "example": "SHIFT TAB", "desc": "Shift key combo"},
    {"command": "REPEAT", "syntax": "REPEAT <n>", "example": "REPEAT 3", "desc": "Repeat previous command n times"},
    {"command": "DEFAULT_DELAY", "syntax": "DEFAULT_DELAY <ms>", "example": "DEFAULT_DELAY 100", "desc": "Set default delay between commands"},
    {"command": "DEFINE", "syntax": "DEFINE <name> <value>", "example": "DEFINE TARGET 192.168.1.1", "desc": "Define a variable/constant"},
    {"command": "VAR", "syntax": "VAR $name = value", "example": "VAR $IP = 10.0.0.1", "desc": "Set runtime variable"},
    {"command": "IF", "syntax": "IF (condition) THEN", "example": "IF ($_OS == WINDOWS) THEN", "desc": "Conditional execution"},
    {"command": "WHILE", "syntax": "WHILE (condition)", "example": "WHILE (TRUE)", "desc": "Loop construct"},
    {"command": "FUNCTION", "syntax": "FUNCTION name()", "example": "FUNCTION attack()", "desc": "Define reusable function"},
    {"command": "WAIT_FOR_BUTTON_PRESS", "syntax": "WAIT_FOR_BUTTON_PRESS", "example": "WAIT_FOR_BUTTON_PRESS", "desc": "Wait for physical button press on device"},
    {"command": "LED_R", "syntax": "LED_R", "example": "LED_R", "desc": "Set LED to red"},
    {"command": "LED_G", "syntax": "LED_G", "example": "LED_G", "desc": "Set LED to green"},
    {"command": "ATTACKMODE", "syntax": "ATTACKMODE <mode>", "example": "ATTACKMODE HID", "desc": "Set USB attack mode (HID, STORAGE, HID STORAGE)"},
    {"command": "SAVE_HOST_KEYBOARD_LOCK_STATE", "syntax": "SAVE_HOST_KEYBOARD_LOCK_STATE", "example": "SAVE_HOST_KEYBOARD_LOCK_STATE", "desc": "Save current keyboard lock state"}
  ]
